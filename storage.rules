rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 상담 녹음 파일: 인증된 사용자만 업로드/다운로드/삭제
    match /consultation-recordings/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 200 * 1024 * 1024
                   && (
                        !('contentType' in request.resource)
                        || request.resource.contentType == null
                        || request.resource.contentType.matches('audio/.*')
                        || request.resource.contentType.matches('video/.*')
                      );
      allow delete: if request.auth != null;
    }

    // 회의 녹음 파일
    match /meeting-recordings/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 200 * 1024 * 1024
                   && (
                        !('contentType' in request.resource)
                        || request.resource.contentType == null
                        || request.resource.contentType.matches('audio/.*')
                        || request.resource.contentType.matches('video/.*')
                      );
      allow delete: if request.auth != null;
    }

    // 등록 상담 녹음 파일
    match /registration-recordings/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 200 * 1024 * 1024
                   && (
                        !('contentType' in request.resource)
                        || request.resource.contentType == null
                        || request.resource.contentType.matches('audio/.*')
                        || request.resource.contentType.matches('video/.*')
                      );
      allow delete: if request.auth != null;
    }

    // 지출결의서 증빙자료 이미지
    match /expenses/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // 기타 파일: 기본 거부
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
